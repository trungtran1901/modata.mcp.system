# =============================================================
# .env.example — MODATA.MCP
# Copy thành .env và điền giá trị thực
# =============================================================

# ── REDIS (schema cache) ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# TTL schema cache tính bằng giây (mặc định 300 = 5 phút)
SCHEMA_CACHE_TTL=300

# ── MCP Gateway ───────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8001

# ── MONGODB ──────────────────────────────────────────────────
MONGO_URI=mongodb://admin:password@mongo-host:27017/admin?authSource=admin
MONGO_DATABASE=generic_instance_v2

# ── POSTGRESQL (session store) ────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=admin
PG_PASSWORD=change_me
PG_DATABASE=vectordb

# ── QDRANT (dùng bởi docs_server) ────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=modata_rag
QDRANT_VECTOR_SIZE=1024

# ── EMBED SERVER (dùng bởi docs_server) ──────────────────────
EMBED_BASE_URL=http://192.168.100.114:8088/v1
EMBED_API_KEY=
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBED_QUERY_INSTRUCTION=Instruct: Given a user query about internal company data, retrieve relevant passages that answer the query\nQuery:
EMBED_TIMEOUT=30

# ── SMTP ─────────────────────────────────────────────────────
MAIL_HOST=mail.hitc.vn
MAIL_PORT=465
MAIL_USE_TLS=false
MAIL_USE_SSL=true
MAIL_USERNAME=modata@hitc.vn
MAIL_PASSWORD=your_mail_password
MAIL_FROM=modata@hitc.vn

# ── RAG TUNING ───────────────────────────────────────────────
RAG_TOP_K=8
RAG_SCORE_THRESHOLD=0.35

# ── COMPANY ──────────────────────────────────────────────────
DEFAULT_COMPANY_CODE=HITC